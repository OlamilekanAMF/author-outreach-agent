# ─────────────────────────────────────────
# AI MODELS (Groq + Gemini)
# ─────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=

# ─────────────────────────────────────────
# PRIMARY OUTREACH CHANNEL (Brevo SMTP)
# ─────────────────────────────────────────
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
SENDER_EMAIL=
SENDER_NAME=

# ─────────────────────────────────────────
# GOOGLE INTEGRATIONS
# ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
GOOGLE_SHEET_ID=
GOOGLE_DOC_ID=

# Optional: For reply detection fallback
GMAIL_CREDENTIALS_JSON=client_secret.json

# ─────────────────────────────────────────
# WEB SEARCH (Discovery)
# ─────────────────────────────────────────
# Google Custom Search (Optional)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ─────────────────────────────────────────
# TRACKING & WEBHOOKS
# ─────────────────────────────────────────
# Base URL for tracking pixels (e.g., https://your-app.com)
TRACKING_BASE_URL=
# Port for the local webhook/tracking server
WEBHOOK_PORT=5000
# SendGrid Webhook Public Key (for ECDSA verification)
SENDGRID_WEBHOOK_PUBLIC_KEY=

# ─────────────────────────────────────────
# AGENT BEHAVIOR & SAFETY
# ─────────────────────────────────────────
AUTHORS_PER_DAY=50
FOLLOW_UP_DELAY_DAYS=4
ENABLE_FOLLOW_UP=true
DRY_RUN=false

# Warmup & Reputation
WARMUP_MODE=false
MAX_BOUNCE_RATE=0.02

# Smart Scheduling (UTC)
ENFORCE_SEND_WINDOW=false
SEND_WINDOW_START_UTC=13
SEND_WINDOW_END_UTC=16

# Quality Control
MANUAL_APPROVAL_REQUIRED=false

# ─────────────────────────────────────────
# REPLY DETECTION (IMAP)
# ─────────────────────────────────────────
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
REPLY_CHECK_DAYS=7

# ─────────────────────────────────────────
# GMAIL SECONDARY CHANNEL
# ─────────────────────────────────────────
GMAIL_SENDER_ADDRESS=
GMAIL_APP_PASSWORD=
GMAIL_SENDER_NAME=
GMAIL_AUTHORS_PER_DAY=20
GMAIL_FOLLOW_UP_DELAY_DAYS=4
GMAIL_ENABLE_FOLLOW_UP=true
GMAIL_DRY_RUN=false

# ─────────────────────────────────────────
# DASHBOARD
# ─────────────────────────────────────────
DASHBOARD_PASSWORD=admin123
DASHBOARD_PORT=8080
